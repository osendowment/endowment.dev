# direnv config — auto-loads only when inside osendowment/website/

# This repo deploys to the OSE Cloudflare account.
# CLOUDFLARE_API_TOKEN_OSE holds the OSE-scoped token; bind it to the
# variable wrangler reads so deploys don't pick up a personal token from
# CLOUDFLARE_API_TOKEN.
export CLOUDFLARE_API_TOKEN=$CLOUDFLARE_API_TOKEN_OSE
