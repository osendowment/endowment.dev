import { Image } from 'astro:assets';
import { identiconDataUrl } from '../lib/identicon.ts';

interface Props {
  name: string;
  email?: string;
  description?: string;
  avatarUrl?: string;
  websiteUrl?: string;
  hasPhoto?: boolean;
  compact?: boolean;
  extraClasses?: string;
}

const { name, email, description, avatarUrl, websiteUrl, hasPhoto, compact, extraClasses } = Astro.props;

const showIdenticon = hasPhoto && !avatarUrl;
// Hash on email (Gravatar-style: trimmed + lowercased) so the identicon stays
// stable for the same identity across name/spelling variations. Fall back to
// name when we don't have an email.
const identiconSeed = email ? email.trim().toLowerCase() : name;
const identiconUrl = showIdenticon ? identiconDataUrl(identiconSeed, 96) : null;

// When the donor has a website, the whole card is one clickable target — wrapper
// becomes <a> instead of <div>. The `--linked` modifier triggers the blue
// hover-border in common.css.
const Tag = websiteUrl ? 'a' : 'div';
const linkAttrs = websiteUrl ? { href: websiteUrl, target: '_blank', rel: 'noopener noreferrer' } : {};
const className = 'donor-mini-profile'
    + (compact ? ' donor-mini-profile--compact' : '')
    + (websiteUrl ? ' donor-mini-profile--linked' : '')
    + (extraClasses ? ' ' + extraClasses : '');
---

<Tag class={className} {...linkAttrs}>
    {!compact && (avatarUrl || identiconUrl) &&
        <div class="donor-avatar">
            {avatarUrl ? (
                <Image src={avatarUrl} alt={name + " photo"} width={96} height={96} loading="lazy" />
            ) : (
                <img src={identiconUrl!} alt={name + " identicon"} width={96} height={96} loading="lazy" />
            )}
        </div>
    }
    <div>
        <h3>{name}</h3>
        {!compact &&
            <i>{description}</i>
        }
    </div>
</Tag>

