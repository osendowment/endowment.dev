import Layout from '../layouts/Layout.astro';
// Single source of truth for the docs index — non-coders edit this
// markdown file (sections, links, and the meeting-minutes table). Astro
// renders <Content /> below; styles in this file shape the output to
// match the rest of the site.
import { Content } from '../content/md/docs-index.md';
---

<Layout title="Foundation Documents — Open Source Endowment" description="Official documents of the Open Source Endowment Foundation including bylaws, certificate of incorporation, board resolutions, and policies." breadcrumbs={[{name: "Home", url: "https://endowment.dev/"}, {name: "Docs", url: "https://endowment.dev/docs/"}]}>
    <article>
        <section class="pagesec pagesec--dark pagesec--tight">
            <div class="container">
                <div class="insec insec--xpad insec--ytight">
                    <div class="squares squares--corner-dark-sw-outer"></div>
                    <div class="squares squares--corner-dark-sw-inner"></div>
                    <div class="squares squares--corner-dark-ne-outer"></div>
                    <div class="squares squares--corner-dark-ne-inner"></div>
                    <div class="sechead sechead--min-height flex-center flex-column">
                        <h1>Docs</h1>
                        <p>
                            The Open Source Endowment Foundation is committed to outstanding transparency.
                            Learn more about our nonprofit through open
                            documents, public endpoints,
                            and <a href="/faq">FAQ</a>
                            — and feel free to discuss them on our
                            <a href="https://github.com/osendowment/foundation" target="_blank">GitHub repo</a>.
                        </p>
                    </div>
                </div>
            </div>
        </section>
        <section class="pagesec">
            <div class="container">
                <div class="insec insec--xpad">
                    <div class="docs-content">
                        <Content />
                    </div>
                </div>
            </div>
        </section>
    </article>
</Layout>

<style>
    .docs-content :global(h2) {
        font-size: var(--font-size-6);
        font-weight: 500;
        margin-top: 1.5rem;
    }
    .docs-content :global(h2:first-child) {
        margin-top: 0;
    }
    .docs-content :global(ul) {
        list-style: disc;
        padding-left: 1.5rem;
    }

    /* Board resolutions and meeting minutes table — same look as the
       previous hardcoded .board-table. The markdown table renders with a
       <thead> we don't want, so hide it. */
    .docs-content :global(table) {
        border-collapse: collapse;
        width: 100%;
    }
    .docs-content :global(table thead) {
        display: none;
    }
    .docs-content :global(table td) {
        padding: 0.5rem 0;
        vertical-align: middle;
        border-bottom: 1px solid var(--color-section-border);
    }
    .docs-content :global(table tr:last-child td) {
        border-bottom: none;
    }
    .docs-content :global(table td:first-child) {
        white-space: nowrap;
        padding-right: 2rem;
        font-family: var(--font-family-mono);
        font-size: var(--font-size-2);
        color: var(--color-text-dark-secondary);
    }
</style>
